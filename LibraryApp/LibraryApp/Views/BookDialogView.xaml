<Window x:Class="LibraryApp.Views.BookDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга" Height="450" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Автор:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Author}" Margin="5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Жанр:" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="2" Grid.Column="1" 
                  SelectedValue="{Binding Genre}" 
                  SelectedValuePath="Content"
                  Margin="5">
            <ComboBoxItem Content="Фантастика"/>
            <ComboBoxItem Content="Детектив"/>
            <ComboBoxItem Content="Наука"/>
            <ComboBoxItem Content="Роман"/>
            <ComboBoxItem Content="Классика"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Год:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Year}" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Страниц:" VerticalAlignment="Center" Margin="5"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Pages}" Margin="5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Оценка (1-5):" VerticalAlignment="Center" Margin="5"/>
        <ComboBox Grid.Row="5" Grid.Column="1" 
                  SelectedValue="{Binding Rating}"
                  SelectedValuePath="Content"
                  Margin="5">
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="4"/>
            <ComboBoxItem Content="5"/>
        </ComboBox>

        <CheckBox Grid.Row="6" Grid.Column="1" Content="Прочитано" IsChecked="{Binding IsRead}" Margin="5" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="OK" Width="80" Margin="5" Click="OkButton_Click"/>
            <Button Content="Отмена" Width="80" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>