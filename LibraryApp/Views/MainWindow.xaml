<Window x:Class="LibraryApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Моя библиотека" Height="600" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Моя библиотека" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Всего книг:" VerticalAlignment="Center" Margin="5"/>
            <TextBlock Text="{Binding TotalBooksCount}" FontWeight="Bold" Margin="0,0,15,0"/>
    
            <TextBlock Text="Прочитано:" VerticalAlignment="Center" Margin="5"/>
            <TextBlock Text="{Binding ReadBooksCount}" FontWeight="Bold" Margin="0,0,15,0"/>
    
            <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="15,5,5,5"/>
            <ComboBox ItemsSource="{Binding Genres}" SelectedItem="{Binding SelectedGenre}" Width="120" Margin="5"/>
    
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="15,5,5,5"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="5"/>
    
            <CheckBox Content="Только непрочитанные" IsChecked="{Binding ShowOnlyUnread}" Margin="15,5,5,5"/>
    
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="15,5,5,5"/>
            <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}" Width="140" Margin="5"/>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Books}" SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False" IsReadOnly="True" Margin="0,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="100"/>
                <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="60"/>
                <DataGridTextColumn Header="Страниц" Binding="{Binding Pages}" Width="70"/>
                <DataGridCheckBoxColumn Header="Прочитано" Binding="{Binding IsRead}" Width="80"/>
                <DataGridTextColumn Header="Оценка" Binding="{Binding Rating}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button Content="Добавить" Command="{Binding AddBookCommand}" Width="100" Height="30" Margin="5"/>
            <Button Content="Редактировать" Command="{Binding EditBookCommand}" Width="100" Height="30" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteBookCommand}" Width="100" Height="30" Margin="5"/>
            <Button Content="Отметить прочитанной" Command="{Binding ToggleReadCommand}" Width="150" Height="30" Margin="5"/>
            <Button Content="Экспорт в CSV" Command="{Binding ExportCsvCommand}" Width="130" Height="30" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>